<?xml version="1.0" encoding="utf-8"?>
<!--
    layout-sw600dp/activity_main.xml — Tablet & smartboard landscape (Phase 3)
    Identical structure to default layout; all sizing via dimen qualifiers.
    Guideline percents adjusted slightly for larger aspect ratios.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/glMetricsTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.69" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/glForecastTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.82" />

        <!-- CIRCULAR MAIN CARD -->
        <FrameLayout
            android:id="@+id/circleCard"
            android:layout_width="@dimen/circle_card_size"
            android:layout_height="@dimen/circle_card_size"
            android:background="@drawable/bg_circle_card"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/glMetricsTop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/circle_card_padding">

                <ImageView
                    android:id="@+id/ivWeatherIcon"
                    android:layout_width="@dimen/icon_size_large"
                    android:layout_height="@dimen/icon_size_large"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/cd_weather_icon"
                    tools:src="@drawable/ic_sun" />

                <TextView
                    android:id="@+id/tvTemperature"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:textColor="#FFFFFFFF"
                    android:textSize="@dimen/text_temperature"
                    android:fontFamily="sans-serif-thin"
                    android:includeFontPadding="false"
                    tools:text="34°C" />

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:textColor="#DDFFFFFF"
                    android:textSize="@dimen/text_date"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.03"
                    tools:text="Sunday, 17 May" />

                <TextView
                    android:id="@+id/tvCondition"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:textColor="#BBFFFFFF"
                    android:textSize="@dimen/text_condition"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="0.04"
                    tools:text="Mostly Sunny" />

            </LinearLayout>
        </FrameLayout>

        <!-- SECONDARY METRICS STRIP -->
        <LinearLayout
            android:id="@+id/metricsStrip"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="@dimen/metrics_strip_padding_h"
            android:paddingEnd="@dimen/metrics_strip_padding_h"
            app:layout_constraintTop_toBottomOf="@id/glMetricsTop"
            app:layout_constraintBottom_toTopOf="@id/glForecastTop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <include android:id="@+id/tileHumidity"   layout="@layout/item_metric_tile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
            <include android:id="@+id/tileFeelsLike"  layout="@layout/item_metric_tile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
            <include android:id="@+id/tileWind"       layout="@layout/item_metric_tile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
            <include android:id="@+id/tileUv"         layout="@layout/item_metric_tile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
            <include android:id="@+id/tilePressure"   layout="@layout/item_metric_tile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
            <include android:id="@+id/tileVisibility" layout="@layout/item_metric_tile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

        </LinearLayout>

        <!-- 5-DAY FORECAST ROW -->
        <LinearLayout
            android:id="@+id/forecastRow"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="@dimen/forecast_row_padding_h"
            android:paddingEnd="@dimen/forecast_row_padding_h"
            app:layout_constraintTop_toBottomOf="@id/glForecastTop"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- HIDDEN TAP ZONE — bottom-left -->
        <View
            android:id="@+id/hiddenTapZone"
            android:layout_width="@dimen/hidden_tap_size"
            android:layout_height="@dimen/hidden_tap_size"
            android:background="@android:color/transparent"
            android:contentDescription=""
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:id="@+id/effectOverlayHost"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false" />

</FrameLayout>
